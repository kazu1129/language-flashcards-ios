      }
    },
    "appInfo.manual.account.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create an account with your email address and password. If email confirmation is enabled, open the confirmation email first, then return to the app and log in. If you forget your password, use Forgot password? on the login screen."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メールアドレスとパスワードでアカウントを作成します。メール確認が有効な場合は、確認メールを開いてからアプリに戻り、ログインしてください。パスワードを忘れた場合は、ログイン画面の「パスワードを忘れた場合」から再設定できます。"
          }
        }
      }
    },
    "appInfo.manual.account.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Account and login"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントとログイン"
          }
        }
      }
    },
    "appInfo.manual.addCards.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "From the add button at the top right of a set screen, you can choose direct entry, camera capture, photo selection, or CSV/TXT import. For CSV/TXT, the app automatically detects the English side and the first-language side even if the order is reversed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "セット画面右上の追加ボタンから、直接入力、写真撮影、写真選択、CSV/TXT読み込みを選べます。CSV/TXTでは英語と日本語の順序が逆でも、アプリが英語側と日本語側を自動判定します。"
          }
        }
      }
    },
    "appInfo.manual.addCards.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adding cards"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カードの追加"
          }
        }
      }
    },
    "appInfo.manual.basic.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log in with your email address and password, choose a flashcard set on Home, then start a session from Start Study. Swipe left or right to move between cards, and tap a card to show the back. The back side shows pronunciation, meanings, and example sentences."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メールアドレスとパスワードでログインしてから、ホームでフラッシュカードセットを選び、「学習を開始」からセッションを始めます。カードは左右スワイプで移動し、タップすると裏面が表示されます。裏面では発音、意味、例文を確認できます。"
          }
        }
      }
    },
    "appInfo.manual.basic.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basic usage"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "基本の使い方"
          }
        }
      }
    },
    "appInfo.manual.editShare.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap a card to edit it. In the card list, you can search, swipe to delete, and use the long-press menu to edit or delete. Use the share button to export a set as TXT, CSV, or PDF."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カードをタップすると編集できます。カード一覧では検索、スワイプ削除、長押しメニューからの編集/削除が使えます。共有ボタンからTXT、CSV、PDFでセットを書き出せます。"
          }
        }
      }
    },
    "appInfo.manual.editShare.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Editing and sharing"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "編集と共有"
          }
        }
      }
    },
    "appInfo.manual.fsrs.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app uses FSRS-lite to estimate each card's difficulty and memory stability. Perfect increases the next interval, while Unsure and Unknown bring the card back sooner. This helps avoid reviewing cards too often after you know them and prioritizes cards you may be close to forgetting."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリはFSRS-liteでカードごとの難しさと記憶の安定度を見ます。「完璧」は出題間隔を伸ばし、「自信なし」「わからなかった」は近いタイミングで再表示します。覚えたカードを必要以上に出さず、忘れそうなカードを優先できるのがメリットです。"
          }
        }
      }
    },
    "appInfo.manual.fsrs.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benefits of FSRS-lite"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FSRS-liteのメリット"
          }
        }
      }
    },
    "appInfo.manual.import.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photo OCR saves rows that contain English words or phrases. CSV/TXT import supports common Japanese encodings and lets you edit the detected rows before saving. If duplicate cards or free-plan limits are detected, the app shows a confirmation before saving."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真OCRでは英語の単語やフレーズを含む行だけを保存します。CSV/TXT読み込みでは日本語で一般的な文字コードにも対応し、保存前に読み取り結果を編集できます。重複や無料プランの上限が見つかった場合は、保存前に確認画面を表示します。"
          }
        }
      }
    },
    "appInfo.manual.import.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OCR and file import"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OCRとファイル取込"
          }
        }
      }
    },
    "appInfo.manual.notifications.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can turn study reminders, daily summaries, anniversary messages, and growth notifications on or off in Settings. If notifications do not appear, check the iOS notification permission for this app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定画面で、学習リマインド、今日の成果、記念日のメッセージ、成長通知のオン/オフを変更できます。通知が表示されない場合は、iOS側でこのアプリの通知許可を確認してください。"
          }
        }
      }
    },
    "appInfo.manual.notifications.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通知"
          }
        }
      }
    },
    "appInfo.manual.premium.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium has two plans: Monthly and Yearly. Set a 2-week free trial for both in App Store Connect. After the free trial ends, billing is handled through the user's Apple ID. Purchase status can be restored from Settings."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレミアムはMonthlyとYearlyの2種類です。どちらもApp Store Connectで2週間無料トライアルを設定し、無料期間終了後にApple IDへ請求されます。購入状態は設定画面から復元できます。"
          }
        }
      }
    },
    "appInfo.manual.premium.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレミアム"
          }
        }
      }
    },
    "appInfo.manual.progress.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each card records your memory rating as Perfect, Still unsure, or Did not know. The Progress tab shows today's study count, calendar, and trend charts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各カードの記憶度を「完璧」「まだ自信ない」「わからなかった」で記録します。成果タブでは今日の学習数、カレンダー、推移グラフを確認できます。"
          }
        }
      }
    },
    "appInfo.manual.progress.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Learning progress"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "学習結果"
          }
        }
      }
    },
    "appInfo.manual.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manual"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "取説"
          }
        }
      }
    },
    "appInfo.privacy.contact.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For questions about privacy or data handling, use the support contact method provided by the app distributor or App Store listing."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーやデータの取り扱いに関する問い合わせは、アプリ配布元またはApp Store掲載情報で案内されているサポート窓口から行ってください。"
          }
        }
      }
    },
    "appInfo.privacy.contact.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contact"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "問い合わせ"
          }
        }
      }
    },
    "appInfo.privacy.data.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app stores flashcards, study history, settings, and notification settings entered by the user on the device. It uses the email address and Supabase user ID for login."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは、ユーザーが入力したフラッシュカード、学習履歴、設定、通知設定を端末内に保存します。ログインのためにメールアドレスとSupabaseユーザーIDを利用します。"
          }
        }
      }
    },
    "appInfo.privacy.data.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data collected"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "収集するデータ"
          }
        }
      }
    },
    "appInfo.privacy.ocr.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photo OCR is processed on the device using Apple's Vision framework. The app does not send photos or recognized card text to an external AI service as part of OCR processing."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真OCRはAppleのVision機能を使って端末内で処理します。OCR処理のために写真や認識したカード本文を外部AIサービスへ送信することはありません。"
          }
        }
      }
    },
    "appInfo.privacy.ocr.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photo OCR"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真OCR"
          }
        }
      }
    },
    "appInfo.privacy.permissions.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photo and camera access is used only to extract words and phrases from memo photos. Notifications are used for study reminders, progress alerts, and anniversary messages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真やカメラへのアクセスは、メモ写真から単語やフレーズを抽出する目的でのみ使用します。通知は学習リマインド、成果通知、記念日通知に使用します。"
          }
        }
      }
    },
    "appInfo.privacy.permissions.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permissions"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "権限"
          }
        }
      }
    },
    "appInfo.privacy.purpose.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saved data is used for flashcard learning, scheduling cards based on the forgetting curve, showing progress, notifications, and creating shared card files."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存データは、フラッシュカード学習、忘却曲線にもとづく出題、成果表示、通知、カードの共有ファイル作成のために利用します。"
          }
        }
      }
    },
    "appInfo.privacy.purpose.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Purpose of use"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データの利用目的"
          }
        }
      }
    },
    "appInfo.privacy.retention.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cards, study history, and settings are kept until the user deletes them in the app or deletes the app. Cards and sets can be deleted in the app. Deleting the app from the device also deletes local data."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カード、学習履歴、設定はユーザーがアプリ内で削除するか、アプリを削除するまで端末に保持されます。カードやセットはアプリ内で削除できます。端末からアプリを削除すると、ローカルデータも削除されます。"
          }
        }
      }
    },
    "appInfo.privacy.retention.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retention and deletion"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持と削除"
          }
        }
      }
    },
    "appInfo.privacy.shareSave.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Card data is stored locally by default. Data is passed to the selected share destination only when the user exports TXT, CSV, or PDF."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カードデータは原則として端末内に保存されます。ユーザーがTXT、CSV、PDF共有を実行した場合のみ、選択した共有先へデータが渡されます。"
          }
        }
      }
    },
    "appInfo.privacy.shareSave.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sharing and storage"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有と保存"
          }
        }
      }
    },
    "appInfo.privacy.subscriptionLink.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When a purchase is made, the Supabase user ID is passed to Apple's purchase options to link the in-app account with subscription status. Payment information is managed by Apple, and the app does not obtain card numbers or similar payment details."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入時にはSupabaseユーザーIDをAppleの購入オプションへ渡し、アプリ内アカウントとサブスクリプション状態を対応づけます。支払い情報そのものはAppleが管理し、アプリはカード番号などを取得しません。"
          }
        }
      }
    },
    "appInfo.privacy.subscriptionLink.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscription linking"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サブスクリプションとの紐づけ"
          }
        }
      }
    },
    "appInfo.privacy.thirdParty.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Login uses Supabase Auth, and subscriptions use Apple StoreKit. Photo OCR is processed with the device's Vision framework. Card content is not sent to external services unless the user uses a sharing feature."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ログインにはSupabase Auth、サブスクリプションにはApple StoreKitを利用します。写真OCRは端末のVision機能で処理します。ユーザーが共有機能を使わない限り、カード内容は外部サービスへ送信されません。"
          }
        }
      }
    },
    "appInfo.privacy.thirdParty.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Third-party services"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "第三者サービス"
          }
        }
      }
    },
    "appInfo.privacy.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy Policy"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシーポリシー"
          }
        }
      }
    },
    "appInfo.terms.cancel.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscriptions through the App Store can be cancelled at any time from the subscription management screen for the user's Apple ID. If cancelled during the free trial period, no future billing will occur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App Store経由のサブスクリプションは、ユーザーのApple IDのサブスクリプション管理画面からいつでも解約できます。無料トライアル期間中に解約した場合、次回以降の請求は発生しません。"
          }
        }
      }
    },
    "appInfo.terms.cancel.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancellation"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解約"
          }
        }
      }
    },
    "appInfo.terms.changes.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app may update these terms or policy documents when features, distribution requirements, or legal requirements change. The latest version shown in the app or App Store listing applies."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "機能、配布要件、法令上の要件が変わった場合、この規約やポリシー文書を更新することがあります。アプリ内またはApp Store掲載情報で表示される最新版が適用されます。"
          }
        }
      }
    },
    "appInfo.terms.changes.heading" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "変更"
          }
        }
      }
    },
    "appInfo.terms.conditions.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is a flashcard app for supporting language learning. Users should register only word lists, notes, and example sentences they have the right to use."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは語学学習を支援するためのフラッシュカードアプリです。ユーザーは、自分が利用権限を持つ単語リスト、メモ、例文を登録してください。"
          }
        }
      }
    },
