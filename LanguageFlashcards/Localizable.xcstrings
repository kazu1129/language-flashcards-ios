    "appInfo.terms.premiumTrial.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium expands limits for cards, OCR, sharing, and analytics. It offers Monthly and Yearly plans, and both include a 2-week free trial. After the free period, price, term, and renewal conditions follow the information shown on the App Store purchase screen."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレミアムではカード数、OCR、共有、分析機能の制限が広がります。MonthlyとYearlyの2種類を提供し、どちらも最初の2週間は無料トライアルです。無料期間終了後の価格、期間、更新条件はApp Storeの購入画面に表示される内容に従います。"
          }
        }
      }
    },
